# Email de destino para solicitações de cancelamento de assinatura (apenas usuários Pro)
VITE_CANCELLATION_EMAIL=suporte@doutorcashapp.com.br

# WhatsApp Bot Number (com código do país, sem +, espaços ou traços. Ex: 5511999999999)
VITE_WHATSAPP_NUMBER=

# URL base da API backend
VITE_API_URL=https://api.doutorcashapp.com.br

# Analytics
VITE_GA_MEASUREMENT_ID=
VITE_MIXPANEL_TOKEN=

# OAuth (opcional)
VITE_GOOGLE_CLIENT_ID=
# EFI Pay — Backend only (nunca expor no frontend)
EFI_ENV=sandbox
EFI_CLIENT_ID_PROD=
EFI_CLIENT_SECRET_PROD=
EFI_CLIENT_ID_SANDBOX=
EFI_CLIENT_SECRET_SANDBOX=
EFI_PIX_KEY=
EFI_CERT_BASE64=
