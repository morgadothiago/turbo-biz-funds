# ============================================================
# OrganizaAI — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# ------------------------------------------------------------
# API
# URL base da API backend
# ------------------------------------------------------------
VITE_API_URL=http://localhost:3000/api

# ------------------------------------------------------------
# Autenticação — Usuários de Teste (desenvolvimento)
# Credenciais padrão usadas quando a variável não está definida:
#   Admin:   admin@financeai.com / admin123
#   Usuário: usuario@financeai.com / user123
# ------------------------------------------------------------
VITE_TEST_ADMIN_EMAIL=admin@financeai.com
VITE_TEST_ADMIN_PASSWORD=admin123

VITE_TEST_USER_EMAIL=usuario@financeai.com
VITE_TEST_USER_PASSWORD=user123

# ------------------------------------------------------------
# Analytics
# Google Analytics 4 — obtenha em https://analytics.google.com
# ------------------------------------------------------------
VITE_GA_MEASUREMENT_ID=

# Mixpanel — obtenha em https://mixpanel.com
VITE_MIXPANEL_TOKEN=

# ------------------------------------------------------------
# OAuth (opcional)
# Google OAuth Client ID
# ------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=
